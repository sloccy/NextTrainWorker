{
  "$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "error",
        "noUnusedFunctionParameters": "warn"
      },
      "performance": {
        "noDelete": "error",
        "noAccumulatingSpread": "error"
      },
      "style": {
        "useConst": "error",
        "useTemplate": "warn",
        "noNonNullAssertion": "warn"
      },
      "suspicious": {
        "noExplicitAny": "warn"
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/src/worker/live/**", "**/src/worker/handlers/**", "**/src/worker/binary/**"],
      "linter": {
        "rules": {
          "complexity": {
            "noForEach": "error"
          }
        }
      }
    },
    {
      "includes": ["**/src/build/**", "**/scripts/**"],
      "linter": {
        "rules": {
          "suspicious": { "noExplicitAny": "off" },
          "style": { "noNonNullAssertion": "off" }
        }
      }
    },
    {
      "includes": ["**/src/tests/**"],
      "linter": {
        "rules": {
          "suspicious": { "noExplicitAny": "off" },
          "style": { "noNonNullAssertion": "off" },
          "correctness": { "noUnusedFunctionParameters": "off" }
        }
      }
    }
  ]
}
